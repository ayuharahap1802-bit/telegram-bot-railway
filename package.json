{
  "name": "telegram-promo-bot",
  "version": "1.0.0",
  "description": "Telegram Bot untuk Promo dan Broadcast",
  "main": "src/main.js",
  "scripts": {
    "start": "node src/main.js",
    "dev": "nodemon src/main.js",
    "migrate": "node src/database/migrationRunner.js",
    "seed": "node src/database/seed.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "postinstall": "node src/database/migrationRunner.js && node src/database/seed.js",
    "build": "echo 'Build completed'",
    "clean": "rm -rf node_modules package-lock.json data/*.db",
    "rebuild": "npm run clean && npm install"
  },
  "dependencies": {
    "telegraf": "^4.15.0",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0",
    "node-cron": "^3.0.3",
    "sqlite3": "^5.1.6",
    "express": "^4.18.2",
    "axios": "^1.5.0",
    "joi": "^17.10.2",
    "helmet": "^7.0.0",
    "rate-limiter-flexible": "^2.4.1",
    "moment": "^2.29.4",
    "uuid": "^9.0.0",
    "compression": "^1.7.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.6.4",
    "eslint": "^8.49.0"
  },
  "engines": {
    "node": "18.x",
    "npm": ">=9.0.0"
  }
}
